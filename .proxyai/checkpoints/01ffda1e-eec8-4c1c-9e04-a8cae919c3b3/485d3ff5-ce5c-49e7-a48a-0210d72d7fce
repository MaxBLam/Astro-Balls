113\t        masse_max = max(self.planetes[0][\"masse\"], self.planetes[1][\"masse\"], self.planetes[2][\"masse\"])\n114\t        for planete_id in range (len(self.planetes)):\n115\t            if masse_max == self.planetes[planete_id][\"masse\"]:\n116\t                masse_max_id = planete_id\n117\t            else:\n118\t                id_list.append(planete_id)\n119\t        self.planetes[masse_max_id][\"vitesse\"] = euclid.Vector2(0, 0)\n120\t        self.planetes[id_list[0]][\"vitesse\"] = self.vitesse_gravitationnelle(self.planetes[masse_max_id], self.planetes[id_list[0]]) * self.facteur_ellipse\n121\t        self.planetes[id_list[1]][\"vitesse\"] = self.vitesse_gravitationnelle(self.planetes[id_list[0]], self.planetes[id_list[1]]) + self.planetes[id_list[0]][\"vitesse\"]\n122\t        self.vitesse_state = True\n123\t\n124\t    def simulation_objet_central_3corps(self, objet_central, objet_orbite1, objet_orbite2):\n125\t        acc_objet_central = self.force_gravitationnelle(objet_central, objet_orbite1) + self.force_gravitationnelle(objet_central, objet_orbite2)\n126\t        acc_objet_orbite1 = self.force_gravitationnelle(objet_orbite1, objet_central) + self.force_gravitationnelle(objet_orbite1, objet_orbite2)\n127\t        acc_objet_orbite2 = self.force_gravitationnelle(objet_orbite2, objet_orbite1) + self.force_gravitationnelle(objet_orbite2, objet_central)\n128\t\n129\t        list_objets = [(objet_central, acc_objet_central), (objet_orbite1, acc_objet_orbite1), (objet_orbite2, acc_objet_orbite2)]\n130\t        list_objets_update = self.mouvement(list_objets)\n131\t\n132\t        if self.camera_mode == \"milieu\":\n133\t            pos_x = ((objet_central[\"position\"].x + objet_orbite1[\"position\"].x) / 2) - (self.width() / self.scale / 2)\n134\t            pos_y = ((objet_central[\"position\"].y + objet_orbite1[\"position\"].y) / 2) - (self.height() / self.scale / 2)\n135\t            self.camera_pos = euclid.Vector2(pos_x, pos_y)\n136\t\n137\t        self.display(list_objets_update)\n138\t\n139\t    def vitesse_simulation2(self):\n140\t        self.planetes[0][\"vitesse\"] = self.vitesse_gravitationnelle(self.planetes[1], self.planetes[0]) * random.uniform(0.4,1.0)\n141\t        self.planetes[1][\"vitesse\"] = self.vitesse_gravitationnelle(self.planetes[0], self.planetes[1]) * random.uniform(0.8,1.2)\n142\t        self.vitesse_state = True\n143\t\n144\t    def simulation_2corps(self, objet_orbite1, objet_orbite2):\n145\t        acc_objet_orbite1 = self.force_gravitationnelle(objet_orbite1, objet_orbite2)\n146\t        acc_objet_orbite2 = self.force_gravitationnelle(objet_orbite2, objet_orbite1)\n147\t\n148\t        list_objets = [(objet_orbite1, acc_objet_orbite1), (objet_orbite2, acc_objet_orbite2)]\n149\t        list_objets_update = self.mouvement(list_objets)\n150\t\n151\t        if self.camera_mode == \"milieu\":\n152\t            pos_x = ((objet_orbite1[\"position\"].x + objet_orbite2[\"position\"].x) / 2) - (self.width() / self.scale / 2)\n153\t            pos_y = ((objet_orbite1[\"position\"].y + objet_orbite2[\"position\"].y) / 2) - (self.height() / self.scale / 2)\n154\t            self.camera_pos = euclid.Vector2(pos_x, pos_y)\n155\t\n156\t        self.display(list_objets_update)\n157\t\n158\t    def force_gravitationnelle(self, obj1, obj2):\n159\t        d_vecteur = obj2[\"position\"] - obj1[\"position\"]\n160\t        distance = d_vecteur.magnitude()\n161\t        distance = max(distance, 1)\n162\t        d_vecteur.normalize()\n163\t        acceleration = d_vecteur * (self.G * obj2[\"masse\"] / distance ** 2)\n164\t        return acceleration\n165\t\n166\t    def vitesse_gravitationnelle(self, obj1, obj2):\n167\t        d_vecteur = obj2[\"position\"] - obj1[\"position\"]\n168\t        distance = d_vecteur.magnitude()\n169\t        d_vecteur.normalize()\n170\t        tangente = euclid.Vector2(-d_vecteur.y, d_vecteur.x)\n171\t        v_orbitale = math.sqrt(self.G * obj1[\"masse\"] / distance)\n172\t        v_orbitale = v_orbitale * tangente\n173\t        return v_orbitale\n174\t\n175\t    @staticmethod\n176\t    def pythagoras(pos):\n177\t        max_height, min_height = max([pos[0][1], pos[1][1]]), min([pos[0][1], pos[1][1]])\n178\t        max_length, min_length = max([pos[0][0], pos[1][0]]), min([pos[0][0], pos[1][0]])\n179\t        height = max_height - min_height\n180\t        length = max_length - min_length\n181\t        hypotenus = math.sqrt((height ** 2 + length ** 2))\n182\t        theta = math.degrees(math.atan2(height, length))\n183\t        return round(hypotenus, 2), round(theta, 2)\n184\t\n185\t    def measuringtape(self):\n186\t        for i in pygame.event.get():\n187\t            if i.type == pygame.MOUSEBUTTONDOWN:\n188\t                if i.button == 1:\n189\t                    pos = pygame.mouse.get_pos()\n190\t                    self.point.append(pos)\n191\t                    self.point = self.point[-2:]\n192\t                    self.measuring_updater_signal.emit()\n193\t\n194\t    def toggle_measuringtape(self, state: bool):\n195\t        self.measuringtape_state = state\n196\t        if not state:\n197\t            self.point.clear()\n198\t            self.measuring_updater_signal.emit()\n199\t\n200\t    def kepler_orbit_helper(self, checked):\n201\t        self.is_helpingorbits = checked\n202\t\n203\t    def kepler(self):\n204\t        color_dimmer = None\n205\t        path = []\n206\t        for i in self.planetes:\n207\t            max_centrum = -1\n208\t            for j in self.planetes:\n209\t                if j == i:\n210\t                    continue\n211\t                gravitational_force = j['masse'] / (i['position'] - j['position']).magnitude_squared() + (1*10 **-10)\n212\t                if gravitational_force > max_centrum:\n213\t                    max_centrum = gravitational_force\n214\t                    self.centrum = j\n215\t                    self.centrum['isCentrum'] = True\n216\t            if self.centrum is None:\n217\t                continue\n218\t            gravitational_parameter = self.G * self.centrum['masse']\n219\t            current_velocity = i['vitesse'] - self.centrum['vitesse']\n220\t            current_position_vector = i['position'] - self.centrum['position']\n221\t            current_position = current_position_vector.magnitude()\n222\t            vectorial_epsilon = (1 / gravitational_parameter *\n223\t                                 ((current_velocity.magnitude_squared() -\n224\t                                   (gravitational_parameter / current_position)) * current_position_vector -\n225\t                                  (current_position_vector.dot(current_velocity)) * current_velocity))\n226\t            epsilon = vectorial_epsilon.magnitude() + (1 * 10 ** -10)\n227\t            omega = math.atan2(vectorial_epsilon.y, vectorial_epsilon.x)\n228\t            paracond = (2 / current_position) - (current_velocity.magnitude_squared() / gravitational_parameter)\n229\t            if paracond <= 0:\n230\t                continue\n231\t            semimajor_axis = 1 / paracond\n232\t            orb_dots = []\n233\t            for k in range(301):\n234\t                theta = (2 * math.pi * k) / 300\n235\t                r = (semimajor_axis * (1 - epsilon ** 2)) / (1 + epsilon * math.cos(theta)) + (1*10**-10)\n236\t                x = (self.centrum['position'].x + r * math.cos(theta + omega))\n237\t                y = (self.centrum['position'].y + r * math.sin(theta + omega))\n238\t                orbit_x, orbit_y = self.pos_objet_orbite(pygame.Vector2(x, y))\n239\t                orb_dots.append((orbit_x, orbit_y))\n240\t                color_dimmer = pygame.Color(i['couleur']).lerp((0, 0, 0), 0.7)\n241\t            orbital_momentum = math.sqrt((self.G * self.centrum['masse']) / current_position)\n242\t            tan_current_position = pygame.Vector2(\n243\t                (current_position_vector.y * -1), current_position_vector.x).normalize()\n244\t            if self.is_helpingorbits:\n245\t                i['vel'] = self.centrum['vel'] + (orbital_momentum * tan_current_position)\n246\t            path.append({'dots': orb_dots, 'color': color_dimmer, 'epsilon': epsilon, 'a': semimajor_axis, 'planet': i,\n247\t                         'vel': i['vel'], 'omega': omega})\n248\t        return path\n249\t\n250\t    def orbit_editor(self):\n251\t        self.is_editingorbits = True\n252\t        receiver_config_button = self.sender()\n253\t        self.p_index = receiver_config_button.property('index') + 1\n254\t        return self.is_editingorbits\n255\t\n256\t    # TODO: needs improvement\n257\t    def orbital_position_editor(self, angle_degrees):\n258\t        orbital_data = None\n259\t        if self.is_editingorbits and self.p_index is not None:\n260\t            theta = math.radians(angle_degrees)\n261\t            planet = self.planetes[self.p_index]\n262\t            if planet:\n263\t                for i in self.kepler():\n264\t                    if i['planet'] == planet:\n265\t                        orbital_data = i\n266\t                        break\n267\t                if orbital_data:\n268\t                    semimajor = orbital_data['a']\n269\t                    ecc = orbital_data['epsilon']\n270\t                    omega = orbital_data['omega']\n271\t                    r = (semimajor * (1 - ecc ** 2)) / (1 + ecc * math.cos(theta))\n272\t                    centrum = self.centrum\n273\t                    planet['position'].x = centrum['position'].x + r * math.cos(theta + omega)  # type: ignore\n274\t                    planet['position'].y = centrum['position'].y + r * math.sin(theta + omega)  # type: ignore\n275\t\n276\t                    inner_sqrt = math.sqrt(\n277\t                        (self.G * centrum['masse']) / ((semimajor * (1-ecc**2)) + 1*10**-10))\n278\t                    urvx = -inner_sqrt * math.sin(theta)\n279\t                    urvy = inner_sqrt * (ecc + math.cos(theta))\n280\t                    rvx = urvx * math.cos(omega) - urvy * math.sin(omega)\n281\t                    rvy = urvx * math.sin(omega) + urvy * math.cos(omega)\n282\t                    planet['vitesse'].x = rvx + centrum['vitesse'].x  # type: ignore\n283\t                    planet['vitesse'].y = rvy + centrum['vitesse'].y  # type: ignore\n284\t\n285\t    # TODO: may delete this later\n286\t    def uopt_editor(self):\n287\t        orbital_data = None\n288\t        if self.p_index is None:\n289\t            return 0.0\n290\t        planet = self.planetes[self.p_index]\n291\t        centrum = self.centrum\n292\t        rpx = planet['position'].x - centrum['position'].x  # type: ignore\n293\t        rpy = planet['position'].y - centrum['position'].y  # type: ignore\n294\t        angle = math.atan2(rpy, rpx)\n295\t        for i in self.kepler():\n296\t            if i['planet'] == planet:\n297\t                orbital_data = i\n298\t                break\n299\t        if orbital_data is not None:\n300\t            theta = angle - orbital_data['omega']\n301\t            theta = theta % (2 * math.pi)\n302\t            return math.degrees(theta)\n303\t        return 0.0\n304\t\n305\t    def mouvement(self, objets):  # objet[0] = objet, objet[1] = acc_objet\n306\t        list_objets_update = []\n307\t        for objet in objets:\n308\t            objet[0][\"vitesse\"] += objet[1] * self.dtime\n309\t            objet[0][\"position\"] += objet[0][\"vitesse\"] * self.dtime\n310\t            list_objets_update.append(objet[0])\n311\t\n312\t        return list_objets_update\n313\t\n314\t    def changer_vue(self):\n315\t        if self.camera_mode == \"free\":\n316\t            self.camera_mode = \"milieu\"\n317\t        elif self.camera_mode == \"milieu\":\n318\t            self.camera_mode = \"follow\"\n319\t        elif self.camera_mode == \"follow\":\n320\t            self.camera_mode = \"free\"\n321\t\n322\t    def pos_objet_orbite(self, pos):\n323\t        relative = pos - self.camera_pos\n324\t\n325\t        if pos != relative:\n326\t            new_world_x = relative.x\n327\t            new_world_y = relative.y\n328\t        else:\n329\t            new_world_x = pos.x\n330\t            new_world_y = pos.y\n331\t\n332\t        return new_world_x * self.scale, new_world_y * self.scale\n333\t\n334\t    def get_planet_surface(self, planete):\n335\t        rayon = int(planete[\"rayon\"] * self.scale)\n336\t        key = (planete[\"nom\"], rayon)\n337\t\n338\t        if key in self.planet_surfaces_cache:\n339\t            return self.planet_surfaces_cache[key]\n340\t\n341\t        image = pygame.image.load(\"./images/Skins/soleil.jpg\")\n342\t        image = pygame.transform.smoothscale(image, (rayon*2, rayon*2))\n343\t        circle_surface = pygame.Surface((rayon*2, rayon*2), pygame.SRCALPHA)\n344\t        pygame.draw.circle(circle_surface, (255, 255, 255, 255), (rayon, rayon), rayon)\n345\t        circle_surface.blit(image, (0, 0), special_flags=pygame.BLEND_RGBA_MIN)\n346\t\n347\t        self.planet_surfaces_cache[key] = circle_surface\n348\t        return circle_surface\n349\t\n350\t    def display(self, planetes: list):\n351\t        self.playscreen.fill((0,0,0))\n352\t\n353\t        for planete in planetes:\n354\t            rx, ry = self.pos_objet_orbite(planete[\"position\"])\n355\t            rayon = planete[\"rayon\"] * self.scale\n356\t\n357\t            if rayon < 1:\n358\t                text = self.font.render(f\"{planete['nom']}\", True, (255, 255, 255))\n359\t                self.playscreen.blit(text, (int(rx) - 20, int(ry) - 7))\n360\t            else:\n361\t                if os.path.exists(\"./images/Skins/soleil.jpg\"):\n362\t                    surface = self.get_planet_surface(planete)\n363\t                    self.playscreen.blit(surface, (rx - rayon, ry - rayon))\n364\t                else:\n365\t                    if all(c < 50 for c in planete[\"couleur\"]) and rayon < 3000:\n366\t                        py